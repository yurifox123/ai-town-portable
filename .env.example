# AI Town LLM config
# Current runtime path uses the custom provider and writes back LLM_PROVIDER=custom.
# The endpoint is expected to be Anthropic/OpenAI-compatible.

LLM_PROVIDER=custom
CUSTOM_API_KEY=your-api-key
CUSTOM_MODEL=kimi-k2.5
CUSTOM_ENDPOINT=https://coding.dashscope.aliyuncs.com/apps/anthropic/v1/messages
CUSTOM_RESPONSE_PATH=content[1].text
CUSTOM_API_KEY_HEADER=x-api-key
CUSTOM_ANTHROPIC_VERSION=2023-06-01

# Optional separate embedding endpoint
CUSTOM_EMBEDDING_ENDPOINT=
CUSTOM_EMBEDDING_RESPONSE_PATH=data[0].embedding

# Data storage
DATABASE_URL=./data/ai-town.db
CHROMA_DB_PATH=./data/chroma

# Server
PORT=3061

# Simulation
TICK_INTERVAL_MS=5000
MAX_AGENTS=10
WORLD_WIDTH=50
WORLD_HEIGHT=50
TIME_SCALE=60

# Optional LangSmith tracing
# LANGCHAIN_API_KEY=your-key
# LANGCHAIN_PROJECT=ai-town
